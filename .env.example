# AI provider configuration
AI_API_KEY=your_api_key
AI_BASE_URL=https://api.deepseek.com/v1
AI_MODEL_NAME=deepseek-chat
AI_API_STYLE=auto
AI_REQUEST_TIMEOUT_MS=15000
AI_ENABLE_CONTEXT_OPTIMIZERS=1
AI_ENABLE_LLMLINGUA=0

# Service ports
API_PORT=3000
WEB_PORT=5173
PAPER_SERVICE_PORT=8090
WEB_HOST=127.0.0.1
PAPER_SERVICE_BIND_HOST=127.0.0.1
VITE_API_PROXY_TARGET=
PAPER_ASSISTANT_BASE_URL=

# Authentication
ALLOW_DEMO_AUTH=0
AUTH_SESSION_TTL_MS=2592000000

# Runtime metadata
RUNTIME_METADATA_BACKEND=file
RUNTIME_POSTGRES_URL=

# Blob storage
RUNTIME_BLOB_BACKEND=file
RUNTIME_BLOB_S3_ENDPOINT=http://127.0.0.1:9010
RUNTIME_BLOB_S3_BUCKET=overleaf-runtime
RUNTIME_BLOB_S3_REGION=us-east-1
RUNTIME_BLOB_S3_ACCESS_KEY_ID=overleafminio
RUNTIME_BLOB_S3_SECRET_ACCESS_KEY=overleafminiosecret
RUNTIME_BLOB_S3_FORCE_PATH_STYLE=1

# Compiler worker
COMPILE_EXECUTION_MODE=host
COMPILE_DOCKER_IMAGE=blang/latex:ubuntu
COMPILE_DOCKER_NETWORK=none
COMPILE_WORKER_ID=

# Split deployment (主站 Docker + 香港论文服务) 建议值
# - 主站机器请参考 .env.main.example
# - 香港论文服务机器请参考 .env.paper-hk.example
PAPER_ASSISTANT_TIMEOUT_MS=25000
PAPER_PUBLIC_DOMAIN=
ACME_EMAIL=
MAIN_IMAGE_TAG=latest
PAPER_HK_IMAGE_TAG=latest
