# 主站机器（api + worker + postgres + minio）部署配置

# 主站 API / AI
AI_API_KEY=your_api_key
AI_BASE_URL=https://api.deepseek.com/v1
AI_MODEL_NAME=deepseek-chat
AI_API_STYLE=auto
AI_REQUEST_TIMEOUT_MS=15000

# 主站端口
API_PORT=3000

# 主站会话
ALLOW_DEMO_AUTH=0
AUTH_SESSION_TTL_MS=2592000000

# 主站数据库
PLATFORM_POSTGRES_DB=overleaf
PLATFORM_POSTGRES_USER=overleaf
PLATFORM_POSTGRES_PASSWORD=overleaf_dev_password
PLATFORM_POSTGRES_PORT=5432

# 主站对象存储（MinIO）
PLATFORM_MINIO_ROOT_USER=overleafminio
PLATFORM_MINIO_ROOT_PASSWORD=overleafminiosecret
PLATFORM_MINIO_PORT=9010
PLATFORM_MINIO_CONSOLE_PORT=9011
RUNTIME_BLOB_S3_BUCKET=overleaf-runtime

# 主站调用香港论文服务（必须是公网 HTTPS 地址）
PAPER_ASSISTANT_BASE_URL=https://papers.your-domain.com
PAPER_ASSISTANT_TIMEOUT_MS=25000

# 镜像 tag（发布与回滚使用）
MAIN_IMAGE_TAG=latest
