{
  "name": "@overleaf-clone/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "sh -c 'vite --host \"${WEB_HOST:-127.0.0.1}\" --port \"${WEB_PORT:-5173}\"'",
    "build": "tsc --noEmit && vite build",
